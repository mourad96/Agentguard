// AgentGuard — auto-generated PRISM model
mdp

module agent
  s : [0..4] init 0;

  [search] s=0 -> 1.000000 : (s'=2);
  [summarize] s=2 -> 1.000000 : (s'=3);
  [write] s=3 -> 1.000000 : (s'=4);
  [finish] s=4 -> 1.000000 : (s'=1);
  [_stay] s=1 -> 1.000000 : (s'=1);

endmodule

// --- Labels ---
label "goal" = s=1;
label "did_finish" = s=1;
label "did_search" = s=2;
label "did_summarize" = s=3;
label "did_write" = s=4;

rewards "steps"
  [search] s=0 : 1;
  [summarize] s=2 : 1;
  [write] s=3 : 1;
  [finish] s=4 : 1;
endrewards